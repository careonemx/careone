# ===== CareOne - plantilla de variables de entorno =====
# Copia este archivo a .env y rellena con valores reales.
# .env NUNCA se sube a git (esta en .gitignore).

# ---- Base de datos (PostgreSQL 18) ----
POSTGRES_DB=careone
POSTGRES_USER=careone
POSTGRES_PASSWORD=cambia-esta-password

# ---- Perfil de Spring ----
# default = desarrollo | prod = produccion
SPRING_PROFILES_ACTIVE=default

# ---- JWT ----
# Secret en Base64 de al menos 32 bytes. Generar uno nuevo, p. ej.:
#   openssl rand -base64 48
JWT_SECRET=cambia-este-secret-base64-de-al-menos-32-bytes
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ---- CORS (origenes del frontend permitidos, separados por coma) ----
# Local: http://localhost  | Prod: https://tu-dominio.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ---- Frontend (build de Vite) ----
# Local fuera de docker:   http://localhost:8080/api
# Docker local/prod:       /api  (el reverse proxy / nginx enruta)
VITE_API_URL=/api

# ---- Puerto del frontend en la DEMO del servidor ----
# Solo se usa con docker-compose.demo.yml. Elige un puerto LIBRE del servidor
# para no chocar con otros proyectos (ej. 8082, 8083...).
FRONTEND_PORT=8082

# ---- Seed Superadmin (Fase 3) ----
SUPERADMIN_EMAIL=superadmin@careone.local
SUPERADMIN_PASSWORD=cambia-esta-password-superadmin
